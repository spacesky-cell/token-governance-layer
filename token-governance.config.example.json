{
  "ledger": {
    "path": ".tgl/ledger.sqlite",
    "retention_days": 30
  },
  "policy": {
    "enabled_strategies": [
      "test_output",
      "build_output",
      "repetitive_log"
    ],
    "protected_content_behavior": "passthrough",
    "persistence_mode": "transformed_only",
    "max_payload_bytes": 2097152,
    "max_stored_original_bytes": 1048576,
    "hook_deadline_ms": 2000,
    "literal_secret_markers": []
  },
  "gateway": {
    "request_timeout_seconds": 10,
    "tool_policy": {
      "allow": [],
      "deny": []
    },
    "backends": []
  }
}
